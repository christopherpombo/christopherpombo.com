---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page Not Found — Christopher Pombo"
  description="This page doesn't exist. Head back to the homepage."
>
  <div class="not-found">
    <p class="not-found__eyebrow">404</p>
    <h1>Page Not Found</h1>
    <p class="not-found__copy">
      I couldn't find the page you were looking for. It may have moved, or the link might be off.
    </p>
    <a class="btn" href="/">Back Home</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding-block: var(--space-7);
  }

  .not-found__eyebrow {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--font-size-h3);
    color: var(--color-accent);
    margin-bottom: var(--space-2);
  }

  .not-found__copy {
    color: var(--color-text-muted);
    margin: var(--space-3) auto var(--space-5);
    max-width: 50ch;
  }
</style>
