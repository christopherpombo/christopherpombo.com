---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Card from "../components/Card.astro";
import CardTitle from "../components/CardTitle.astro";

const socialCards = [
  {
    title: "LinkedIn",
    subtitle: "Since August 2025",
    description:
      "A professional space to share my career journey, leadership experiences, and future goals.",
    href: "https://www.linkedin.com/in/christopher-pombo-2b324a271/",
  },
  {
    title: "YouTube",
    subtitle: "Since September 2025",
    description: "A creative space where I post videos about my interests, projects, and personal journey.",
    href: "https://www.youtube.com/@christopherpomboo",
  },
  {
    title: "Instagram",
    subtitle: "Since July 2017",
    description: "A glimpse into my everyday life, and interests outside of the Academic and Air Force career.",
    href: "https://www.instagram.com/christopherpomboo/",
  },
  {
    title: "Strava",
    subtitle: "Since 2024",
    description: "Where I log my runs and training.",
    href: "https://www.strava.com/athletes/122442696",
  },
];
---

<BaseLayout
  title="Contact — Christopher Pombo"
  description="Get in touch with Christopher Pombo via email, LinkedIn, YouTube, Instagram, or Strava."
>
  <PageHeader title="Contact" subtitle="A page dedicated to my contacts & other media platforms." />

  <h2 class="visually-hidden">Ways to reach me</h2>
  <div class="card-grid social-grid">
    {
      socialCards.map((card) => (
        <a class="card-link" href={card.href} target="_blank" rel="noopener noreferrer">
          <Card>
            <CardTitle title={card.title} subtitle={card.subtitle} />
            <p>{card.description}</p>
          </Card>
        </a>
      ))
    }
  </div>

  <a class="card-link direct-contact" href="mailto:christopherpombo4@gmail.com">
    <Card>
      <CardTitle title="Direct Contact" subtitle="Business Email" />
      <p>For direct inquiries please write to christopherpombo4@gmail.com.</p>
    </Card>
  </a>
</BaseLayout>

<style>
  .direct-contact {
    margin-top: var(--space-4);
  }

  .social-grid {
    grid-template-columns: repeat(4, 1fr);
  }

  @media (max-width: 820px) {
    .social-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 520px) {
    .social-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
