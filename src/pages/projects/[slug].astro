---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/Card.astro";

export async function getStaticPaths() {
  const entries = await getCollection("projects");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const year = entry.data.date.toLocaleDateString("en-US", { year: "numeric", timeZone: "UTC" });

const allProjectImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/projects/**/*.{jpg,jpeg,png,webp}",
  { eager: true }
);
const screenshots = Object.entries(allProjectImages)
  .filter(([path]) => path.includes(`/${entry.id}/`) || path.includes(`/${entry.id}.`))
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([path, mod]) => {
    const filename = path.split("/").pop() ?? "";
    const label = filename.replace(/\.[^.]+$/, "").replace(/[-_]/g, " ");
    return { image: mod.default, label };
  });
---

<BaseLayout title={`${entry.data.title} — Christopher Pombo`} description={entry.data.summary}>
  <article class="project-detail">
    <div class="project-detail__text">
      <a class="back-link" href="/projects">&larr; Back to Projects</a>
      <h1>{entry.data.title}</h1>
      <p class="project-detail__year">{year}</p>

      <ul class="stack-tags">
        {entry.data.stack.map((tech) => <li>{tech}</li>)}
      </ul>
    </div>

    {
      screenshots.length > 0 && (
        <div class="project-detail__screenshots">
          {screenshots.map(({ image, label }) => (
            <Card>
              <Image
                src={image}
                alt={`${entry.data.title} — ${label} screen`}
                width={600}
                densities={[1, 2]}
                loading="lazy"
                decoding="async"
              />
            </Card>
          ))}
        </div>
      )
    }

    <div class="project-detail__text">
      <div class="project-detail__body">
        <Content />
      </div>

      {
        entry.data.links && (
          <div class="project-detail__links">
            {entry.data.links.github && (
              <a class="btn" href={entry.data.links.github} target="_blank" rel="noopener noreferrer">
                GitHub
              </a>
            )}
            {entry.data.links.appStore && (
              <a class="btn" href={entry.data.links.appStore} target="_blank" rel="noopener noreferrer">
                App Store
              </a>
            )}
            {entry.data.links.live && (
              <a class="btn" href={entry.data.links.live} target="_blank" rel="noopener noreferrer">
                Live
              </a>
            )}
          </div>
        )
      }
    </div>
  </article>
</BaseLayout>

<style>
  .project-detail__text {
    max-width: 70ch;
  }

  .back-link {
    display: inline-block;
    font-size: var(--font-size-small);
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: var(--space-4);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .project-detail__year {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-accent);
    margin-top: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .stack-tags {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .stack-tags li {
    font-size: var(--font-size-meta);
    font-weight: 500;
    letter-spacing: var(--letter-spacing-uppercase);
    text-transform: uppercase;
    color: var(--color-text-muted);
    background: var(--color-surface);
    padding: var(--space-1) var(--space-2);
    border-radius: 2px;
  }

  .project-detail__screenshots {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
    max-width: 900px;
    margin-block: var(--space-6);
  }

  .project-detail__screenshots :global(.card) {
    padding: var(--space-2);
    display: flex;
  }

  .project-detail__screenshots :global(img) {
    width: 100%;
    height: auto;
    border-radius: 2px;
  }

  .project-detail__body {
    color: var(--color-text);
  }

  .project-detail__links {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }

  @media (max-width: 720px) {
    .project-detail__screenshots {
      grid-template-columns: 1fr;
      max-width: 320px;
      margin-inline: auto;
    }
  }
</style>
