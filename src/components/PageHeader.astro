---
interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<header class="page-header">
  <h1>{title}</h1>
  <p class="page-header__lede">{subtitle}</p>
</header>

<style>
  .page-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: var(--space-6);
  }

  .page-header__lede {
    color: var(--color-text-muted);
    margin-top: var(--space-3);
  }
</style>
