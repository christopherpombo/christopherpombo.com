---
import "@fontsource/poppins/700.css";
import "@fontsource/mulish/400.css";
import "@fontsource/mulish/500.css";
import "@fontsource/mulish/700.css";
import "../styles/tokens.css";
import "../styles/global.css";
import SocialIcons from "../components/SocialIcons.astro";
import poppins700Url from "@fontsource/poppins/files/poppins-latin-700-normal.woff2?url";
import mulish400Url from "@fontsource/mulish/files/mulish-latin-400-normal.woff2?url";

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: "website" | "profile" | "article";
}

const { title, description, image = "/og-image.png", type = "website" } = Astro.props;

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/resume", label: "Resume" },
  { href: "/goals", label: "Goals" },
  { href: "/projects", label: "Projects" },
  { href: "/contact", label: "Contact" },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);

const canonicalUrl = new URL(currentPath, Astro.site);
const ogImageUrl = new URL(image, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <link rel="preload" as="font" type="font/woff2" href={poppins700Url} crossorigin="anonymous" />
    <link rel="preload" as="font" type="font/woff2" href={mulish400Url} crossorigin="anonymous" />

    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>

    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Christopher Pombo" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner container">
        <a class="brand" href="/">
          <span class="brand__square" aria-hidden="true"></span>
          <span class="brand__name">Christopher Pombo</span>
          <span class="brand__divider" aria-hidden="true">/</span>
          <span class="brand__subtitle">Personal Site</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          <ul>
            {
              navLinks.map((link) => (
                <li>
                  <a href={link.href} aria-current={isActive(link.href) ? "page" : undefined}>
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner container">
        <p class="footer-copyright">&copy; 2026 Christopher Pombo.</p>
        <div class="footer-links">
          <div class="footer-block">
            <p class="footer-block__label">Write</p>
            <a class="footer-block__email" href="mailto:christopherpombo4@gmail.com"
              >christopherpombo4@gmail.com</a
            >
          </div>
          <div class="footer-block">
            <p class="footer-block__label">Follow</p>
            <SocialIcons />
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding-block: var(--space-4);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--color-text);
  }

  .brand__square {
    display: inline-block;
    width: var(--section-square-size);
    height: var(--section-square-size);
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .brand__name {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.25rem;
  }

  .brand__divider {
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .brand__subtitle {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--font-size-meta);
    letter-spacing: var(--letter-spacing-uppercase);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .site-nav ul {
    display: flex;
    flex-wrap: wrap;
    list-style: none;
    gap: var(--space-4);
    padding: 0;
  }

  .site-nav a {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--font-size-nav);
    letter-spacing: var(--letter-spacing-uppercase);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text);
    transition: color var(--transition-fast);
  }

  .site-nav a:hover {
    color: var(--color-accent);
  }

  .site-nav a[aria-current="page"] {
    color: var(--color-accent);
  }

  .site-main {
    background: var(--color-bg);
    flex: 1;
    padding-block: var(--space-6);
  }

  .site-footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
  }

  .site-footer__inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-5);
    padding-block: var(--space-5);
  }

  .footer-copyright {
    font-size: var(--font-size-small);
    color: var(--color-text-muted);
  }

  .footer-links {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .footer-block__label {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: var(--font-size-small);
    color: var(--color-text);
    margin-bottom: var(--space-1);
  }

  .footer-block__email {
    font-size: var(--font-size-small);
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .footer-block__email:hover {
    color: var(--color-accent);
  }

  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
</style>
