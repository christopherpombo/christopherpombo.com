---
import "@fontsource/poppins/600.css";
import "@fontsource/poppins/700.css";
import "@fontsource/mulish/400.css";
import "@fontsource/mulish/500.css";
import "@fontsource/mulish/700.css";
import "../styles/tokens.css";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/resume", label: "Resume" },
  { href: "/goals", label: "Goals" },
  { href: "/projects", label: "Projects" },
  { href: "/contact", label: "Contact" },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner container">
        <a class="brand" href="/">
          <span class="brand__square" aria-hidden="true"></span>
          <span class="brand__name">Christopher Pombo</span>
          <span class="brand__divider" aria-hidden="true">/</span>
          <span class="brand__subtitle">Personal Site</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          <ul>
            {
              navLinks.map((link) => (
                <li>
                  <a href={link.href} aria-current={isActive(link.href) ? "page" : undefined}>
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner container">
        <p class="footer-copyright">&copy; 2026 Christopher Pombo.</p>
        <div class="footer-links">
          <div class="footer-block">
            <p class="footer-block__label">Write</p>
            <a class="footer-block__email" href="mailto:christopherpombo4@gmail.com"
              >christopherpombo4@gmail.com</a
            >
          </div>
          <div class="footer-block">
            <p class="footer-block__label">Follow</p>
            <div class="footer-social">
              <a href="#" aria-label="LinkedIn">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                  <path
                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                  ></path>
                </svg>
              </a>
              <a href="#" aria-label="YouTube">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                  <path
                    d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
                  ></path>
                </svg>
              </a>
              <a href="#" aria-label="Instagram">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                  <path
                    d="M12 0C8.74 0 8.333.014 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.014 8.333 0 8.74 0 12s.014 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.986 8.74 24 12 24s3.667-.014 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.014-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.014 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zM12 5.838c-3.405 0-6.162 2.76-6.162 6.162 0 3.405 2.76 6.162 6.162 6.162 3.405 0 6.162-2.76 6.162-6.162 0-3.405-2.76-6.162-6.162-6.162zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405c0 .795-.646 1.44-1.44 1.44-.795 0-1.44-.646-1.44-1.44 0-.794.646-1.439 1.44-1.439.793-.001 1.44.645 1.44 1.439z"
                  ></path>
                </svg>
              </a>
              <a href="#" aria-label="Strava">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                  <path
                    d="M15.387 17.944l-2.089-4.116h-3.065L15.387 24l5.15-10.172h-3.066m-7.008-5.599l2.836 5.598h4.172L10.463 0l-7 13.828h4.169"
                  ></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding-block: var(--space-4);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: var(--color-text);
  }

  .brand__square {
    display: inline-block;
    width: var(--section-square-size);
    height: var(--section-square-size);
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .brand__name {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.25rem;
  }

  .brand__divider {
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .brand__subtitle {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--font-size-meta);
    letter-spacing: var(--letter-spacing-uppercase);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .site-nav ul {
    display: flex;
    flex-wrap: wrap;
    list-style: none;
    gap: var(--space-4);
    padding: 0;
  }

  .site-nav a {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--font-size-nav);
    letter-spacing: var(--letter-spacing-uppercase);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text);
    transition: color var(--transition-fast);
  }

  .site-nav a:hover {
    color: var(--color-accent);
  }

  .site-nav a[aria-current="page"] {
    color: var(--color-accent);
  }

  .site-main {
    background: var(--color-bg);
    flex: 1;
    padding-block: var(--space-6);
  }

  .site-footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
  }

  .site-footer__inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-5);
    padding-block: var(--space-5);
  }

  .footer-copyright {
    font-size: var(--font-size-small);
    color: var(--color-text-muted);
  }

  .footer-links {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .footer-block__label {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: var(--font-size-small);
    color: var(--color-text);
    margin-bottom: var(--space-1);
  }

  .footer-block__email {
    font-size: var(--font-size-small);
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .footer-block__email:hover {
    color: var(--color-accent);
  }

  .footer-social {
    display: flex;
    gap: var(--space-3);
  }

  .footer-social a {
    color: var(--color-text);
    line-height: 0;
    transition: color var(--transition-fast);
  }

  .footer-social a:hover {
    color: var(--color-accent);
  }

  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
</style>
